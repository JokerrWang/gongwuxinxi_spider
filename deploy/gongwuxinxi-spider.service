[Unit]
Description=天津公职/国企招聘信息汇总
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/gongwuxinxi_spider
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStart=/usr/bin/node /opt/gongwuxinxi_spider/src/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
